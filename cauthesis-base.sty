\RequirePackage{hyperref}
\RequirePackage{natbib}
\RequirePackage{indentfirst}
\RequirePackage{array}
\RequirePackage{calc}
\RequirePackage{etoolbox}
\RequirePackage{ifthen}
\RequirePackage{emptypage}
\RequirePackage{zhnumber}
\RequirePackage[section]{placeins}
\RequirePackage[normalem]{ulem}
% Pandoc 兼容（如用 pandoc 转 docx 后保留这些占位命令）
\providecommand{\real}[1]{#1}
\providecommand{\tightlist}{\setlength{\itemsep}{0pt}\setlength{\parskip}{0pt}}
\providecommand{\passthrough}[1]{#1}

% ============================================================
% 2. 字体（Fandol 系列：TeX Live 自带，开源合规）
% ============================================================
\IfFontExistsTF{TeX Gyre Termes}
  {\setmainfont{TeX Gyre Termes}}
  {\setmainfont{Times New Roman}}
\IfFontExistsTF{TeX Gyre Heros}
  {\setsansfont{TeX Gyre Heros}}
  {\setsansfont{Helvetica}}
\IfFontExistsTF{TeX Gyre Cursor}
  {\setmonofont{TeX Gyre Cursor}}
  {\setmonofont{Courier}}

% macOS 优先用系统中文字体；其他系统回退到 TeX Live 自带的 Fandol。
% \kaishu / \fangsong 字体族暴露给正文使用（强调、引文等场景）。
\IfFontExistsTF{Songti SC}
  {%
    \setCJKmainfont[BoldFont=Songti SC Bold]{Songti SC}
    \setCJKsansfont{Heiti SC}
    \setCJKmonofont{Songti SC}
    \newCJKfontfamily\songti{Songti SC}
    \newCJKfontfamily\heiti{Heiti SC}
    \newCJKfontfamily\kaishu{STKaiti}
    \newCJKfontfamily\fangsong{STFangsong}
  }
  {%
    \setCJKmainfont[BoldFont=FandolHei, ItalicFont=FandolKai]{FandolSong}
    \setCJKsansfont{FandolHei}
    \setCJKmonofont{FandolFang}
    \newCJKfontfamily\songti{FandolSong}
    \newCJKfontfamily\heiti{FandolHei}
    \newCJKfontfamily\kaishu{FandolKai}
    \newCJKfontfamily\fangsong{FandolFang}
  }

% ============================================================
% 3. 版芯（CAU 规范：左 30 / 右 25 / 上 30 / 下 25 mm；页眉 23mm，页脚 18mm）
% headheight + headsep = 30mm - 23mm = 7mm（页眉顶到页面顶 23mm）
% footskip = 25mm - 18mm = 7mm（页脚基线到页面底 18mm）
% ============================================================
\geometry{
  a4paper,
  left   = 30mm,
  right  = 25mm,
  top    = 30mm,
  bottom = 25mm,
  headheight = 5mm,
  headsep    = 2mm,
  footskip   = 7mm,
}

% ============================================================
% 4. 行距（CAU 规范：正文及图表题等正文性内容 20pt；目录条目 18pt）
% 各字号命令通过 \fontsize{X}{20pt} 显式指定基线，因此 \baselinestretch
% 必须保持 1，否则 baselineskip 会被再乘一遍（曾经设为 1.389 是个 bug，
% 把 20pt 拉到了 27.78pt）。文档级默认字号在 \AtBeginDocument 切到 \xiaosi。
% ============================================================
\renewcommand{\baselinestretch}{1}
\newcommand{\cau@bodybaselineskip}{20pt}
\newcommand{\cau@tocbaselineskip}{18pt}

% ---- 首行缩进 2 字符 ----
\setlength{\parindent}{2em}

% ============================================================
% 5. 字号命令（中文字号对照）
% ============================================================
\newcommand{\chuhao}{\fontsize{42pt}{50.4pt}\selectfont}
\newcommand{\yihao}{\fontsize{26pt}{31.2pt}\selectfont}
\newcommand{\xiaoyi}{\fontsize{24pt}{28.8pt}\selectfont}
\newcommand{\erhao}{\fontsize{22pt}{26.4pt}\selectfont}
\newcommand{\xiaoer}{\fontsize{18pt}{21.6pt}\selectfont}
\newcommand{\sanhao}{\fontsize{16pt}{19.2pt}\selectfont}
\newcommand{\xiaosan}{\fontsize{15pt}{\cau@bodybaselineskip}\selectfont}
\newcommand{\sihao}{\fontsize{14pt}{\cau@bodybaselineskip}\selectfont}
\newcommand{\bansi}{\fontsize{13pt}{\cau@bodybaselineskip}\selectfont}
\newcommand{\xiaosi}{\fontsize{12pt}{\cau@bodybaselineskip}\selectfont}
\newcommand{\wuhao}{\fontsize{10.5pt}{\cau@bodybaselineskip}\selectfont}
\newcommand{\xiaowu}{\fontsize{9pt}{\cau@bodybaselineskip}\selectfont}
\newcommand{\liuhao}{\fontsize{7.5pt}{9pt}\selectfont}
\newcommand{\cau@headfootfont}{\fontsize{9pt}{10.8pt}\selectfont\songti}

% ============================================================
% 6. 章节编号（一级中文"第N章"，二三级阿拉伯）
% ============================================================
\renewcommand{\thesection}{第\zhnum{section}章}
\renewcommand{\thesubsection}{\arabic{section}.\arabic{subsection}}
\renewcommand{\thesubsubsection}{\arabic{section}.\arabic{subsection}.\arabic{subsubsection}}

% ============================================================
% 7. 章节标题样式（titlesec）
% ============================================================
% 一级：居中，黑体，三号 (16pt)，粗体；段前段后正文 1 行 (20pt)
\newcommand{\cau@levelonefont}{\centering\heiti\sanhao\bfseries}
\titleformat{\section}
  {\cau@levelonefont}{\thesection}{1em}{}
\titlespacing*{\section}{0pt}{20pt}{20pt}

% 二级：左对齐，黑体，四号 (14pt)，不加粗
\titleformat{\subsection}
  {\heiti\sihao}{\thesubsection}{1em}{}
\titlespacing*{\subsection}{0pt}{20pt}{20pt}

% 三级：左对齐，黑体，小四号 (12pt)，不加粗
\titleformat{\subsubsection}
  {\heiti\xiaosi}{\thesubsubsection}{1em}{}
\titlespacing*{\subsubsection}{0pt}{20pt}{20pt}

% 页眉 \rightmark 显示当前一级标题；研究生规范要求右侧为一级标题名称
\renewcommand{\sectionmark}[1]{%
  \ifdefstring{\cauthesis@type}{undergraduate}
    {\markright{\thesection\quad #1}}
    {\markright{#1}}%
}

% ============================================================
% 8. 页眉页脚（mainmatter / frontmatter 双 fancypagestyle）
% ============================================================
\pagestyle{fancy}
\fancyhf{}

% mainmatter（正文章节）：左标题 + 右"第N章 标题" + 文武线 + 居中页码
\fancypagestyle{cau-mainmatter}{%
  \fancyhf{}%
  \fancyhead[L]{\cau@headfootfont \cauthesis@headertext}%
  \fancyhead[R]{\cau@headfootfont \nouppercase{\rightmark}}%
  \fancyfoot[C]{\cau@headfootfont \thepage}%
  % 上粗下细文武线（CAU 规范 ~3 磅）：上 1.5pt + 间距 1pt + 下 0.5pt
  \renewcommand{\headrule}{%
    \hrule\@height1.5pt\@width\headwidth\vskip1pt%
    \hrule\@height0.5pt\@width\headwidth\vskip-3pt%
  }%
  \renewcommand{\footrulewidth}{0pt}%
}

% frontmatter（摘要/目录/图清单等）：无页眉，仅居中罗马页码
\fancypagestyle{cau-frontmatter}{%
  \fancyhf{}%
  \fancyfoot[C]{\cau@headfootfont \thepage}%
  \renewcommand{\headrule}{}%
  \renewcommand{\headrulewidth}{0pt}%
  \renewcommand{\footrulewidth}{0pt}%
}

\pagestyle{cau-mainmatter}

% 页码切换命令
\newcommand{\frontmatterpages}{\pagenumbering{Roman}\setcounter{page}{1}\pagestyle{cau-frontmatter}}
\newcommand{\mainmatterpages}{\pagenumbering{arabic}\setcounter{page}{1}\pagestyle{cau-mainmatter}}

% ============================================================
% 9. 目录
% ============================================================
\renewcommand{\contentsname}{目录}
\renewcommand{\cfttoctitlefont}{\hfill\heiti\sanhao\bfseries}
\renewcommand{\cftaftertoctitle}{\hfill}
\setlength{\cftbeforetoctitleskip}{20pt}
\setlength{\cftaftertoctitleskip}{20pt}
\renewcommand{\cftsecfont}{\songti\fontsize{14pt}{\cau@tocbaselineskip}\selectfont}
\renewcommand{\cftsecpagefont}{\songti\fontsize{14pt}{\cau@tocbaselineskip}\selectfont}
\renewcommand{\cftsecleader}{\cftdotfill{\cftdotsep}}
\setlength{\cftsecindent}{0pt}
\setlength{\cftsubsecindent}{2em}
\renewcommand{\cftsubsecfont}{\songti\fontsize{12pt}{\cau@tocbaselineskip}\selectfont}
\renewcommand{\cftsubsecpagefont}{\songti\fontsize{12pt}{\cau@tocbaselineskip}\selectfont}
\setlength{\cftsubsubsecindent}{4.5em}
\renewcommand{\cftsubsubsecfont}{\songti\fontsize{12pt}{\cau@tocbaselineskip}\selectfont}
\renewcommand{\cftsubsubsecpagefont}{\songti\fontsize{12pt}{\cau@tocbaselineskip}\selectfont}
% 中文章号宽度（"第一章" 需 ~4em，否则 tocloft 会把标题换行）
\setlength{\cftsecnumwidth}{4em}
\setlength{\cftsubsecnumwidth}{3em}
\setlength{\cftsubsubsecnumwidth}{4em}
% 目录条目间不加额外段前空白，统一 18pt 行距（匹配 Word 模板）
\setlength{\cftbeforesecskip}{0pt}
