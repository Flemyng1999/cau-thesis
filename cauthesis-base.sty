% 参考文献标题（natbib \bibliography 自动调用）
\renewcommand{\bibsection}{%
  \phantomsection\addcontentsline{toc}{section}{参考文献}%
  \markright{参考文献}%
  \centerheading{参考文献}%
}

% 正文开始（切换页码）
\newcommand{\startmainbody}{\mainmatterpages\setcounter{section}{0}}

% 文档级默认字号：小四号宋体 + 行距 20pt（覆盖 LaTeX 默认 \normalsize 12pt/14.4pt）
\AtBeginDocument{\xiaosi}

% ============================================================
% 16. 模块化 / SSOT：封面字段 getter + 通用 key-value 变量
% ============================================================
% 封面字段在 cls 中以 \def\@xxx{...} 内部存储，下面把共用字段
% 暴露为正文可调用的 \thethesisxxx getter。各 cls 视需要追加自己
% 独有字段（如研究生的 \@studentid 等）。
\AtBeginDocument{%
  \@ifundefined{@thesistitle}{}{\let\thethesistitle\@thesistitle}%
  \@ifundefined{@thesistitleen}{}{\let\thethesistitleen\@thesistitleen}%
  \@ifundefined{@thesisauthor}{}{\let\thethesisauthor\@thesisauthor}%
  \@ifundefined{@advisor}{}{\let\thethesisadvisor\@advisor}%
  \@ifundefined{@coadvisor}{}{\let\thethesiscoadvisor\@coadvisor}%
  \@ifundefined{@major}{}{\let\thethesismajor\@major}%
  \@ifundefined{@college}{}{\let\thethesiscollege\@college}%
  \@ifundefined{@thesisdate}{}{\let\thethesisdate\@thesisdate}%
  % 研究生特有字段（cls 未定义时跳过）
  \@ifundefined{@studentid}{}{\let\thethesisstudentid\@studentid}%
  \@ifundefined{@classify}{}{\let\thethesisclassify\@classify}%
  \@ifundefined{@unitcode}{}{\let\thethesisunitcode\@unitcode}%
  \@ifundefined{@confidlevel}{}{\let\thethesisconfidlevel\@confidlevel}%
  \@ifundefined{@thesisdegree}{}{\let\thethesisdegree\@thesisdegree}%
  \@ifundefined{@degreecategory}{}{\let\thethesisdegreecategory\@degreecategory}%
  \@ifundefined{@researchfield}{}{\let\thethesisresearchfield\@researchfield}%
  \@ifundefined{@fieldname}{}{\let\thethesisfieldname\@fieldname}%
}

% 通用 key-value 变量：\thesisvar{key}{value} 注册一次，\thevar{key} 引用
% 适用于研究对象、方法名称、数据集、关键参数等正文里反复出现的占位串。
% 未注册的 key 会展开为空，并在编译日志里给出警告便于排查。
\newcommand{\thesisvar}[2]{\@namedef{cau@var@#1}{#2}}
\newcommand{\thevar}[1]{%
  \@ifundefined{cau@var@#1}{%
    \PackageWarning{cauthesis-base}{thesisvar `#1' undefined; expanded to empty}%
  }{\@nameuse{cau@var@#1}}%
}

\endinput
