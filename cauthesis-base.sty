\setlength{\cftbeforesubsubsecskip}{0pt}

% ============================================================
% 10. 图表 caption（CAU 规范：黑体五号 居中，图下方表上方）
% ============================================================
\renewcommand{\figurename}{图}
\renewcommand{\tablename}{表}
\renewcommand{\listfigurename}{插图清单}
\renewcommand{\listtablename}{附表清单}
\DeclareCaptionFont{cauwuheiti}{\heiti\wuhao}
\captionsetup{font=cauwuheiti, labelsep=space, justification=centering, singlelinecheck=true}
\captionsetup[figure]{position=below}
\captionsetup[table]{position=above}

% 图表公式编号按章：图 1-1, 表 2-2, 公式 3-10
\renewcommand{\thefigure}{\arabic{section}-\arabic{figure}}
\renewcommand{\thetable}{\arabic{section}-\arabic{table}}
\renewcommand{\theequation}{\arabic{section}-\arabic{equation}}
\@addtoreset{figure}{section}
\@addtoreset{table}{section}
\@addtoreset{equation}{section}

% ============================================================
% 11. 三线表 + 表内自动五号宋体（CAU 规范）
% ============================================================
\setlength{\heavyrulewidth}{1.5pt}
\setlength{\lightrulewidth}{0.75pt}
\setlength{\cmidrulewidth}{0.75pt}
\AddToHook{env/tabular/begin}{\wuhao\songti}
\AddToHook{env/longtable/begin}{\wuhao\songti}
% 图注/表注：小五号宋体，首行缩进 2 字符（按正文字号计），后续行回到左边界
\newcommand{\figurenote}[1]{%
  \par\noindent\hspace*{2em}{\xiaowu\songti 注：#1\par}%
}
\newcommand{\tablenote}[1]{%
  \par\noindent\hspace*{2em}{\xiaowu\songti 注：#1\par}%
}

% ============================================================
% 12. 参考文献（natbib + GB/T 7714-2015）
% 研究生：著者-出版年制（caugradthesis）
% 本科生：顺序编码制 [1] 上标（cauugthesis；规范要求“置于文字末尾右上标”）
% ============================================================
\ifdefstring{\cauthesis@type}{undergraduate}{%
  \bibliographystyle{gbt7714-numerical}%
  \setcitestyle{numbers,square,super,sort&compress,citesep={,}}%
}{%
  \bibliographystyle{gbt7714-author-year}%
  \setcitestyle{authoryear,round,semicolon,aysep={,},yysep={,}}%
}
\renewcommand{\bibfont}{\wuhao\songti}
% 参考文献条目内/条目间统一 20pt 行距（\wuhao 已设置 baseline=20pt，禁用条目间额外空白）
\setlength{\bibsep}{0pt}

% ============================================================
% 13. hyperref 配置
% ============================================================
\hypersetup{
  colorlinks=true, linkcolor=black, citecolor=black, urlcolor=black,
  bookmarksnumbered=true, bookmarksopen=true,
}

% ============================================================
% 14. 共用 helper（特殊页面标题居中黑体三号加粗）
% ============================================================
% 段前/段后均按 CAU 规范取 1 行 (= 20pt)。
% before 用 \vspace*：在页顶也不会被丢弃（保证摘要等独立页有 20pt 上方空间）。
% after 用 \addvspace：与后续段距取最大值，避免叠加。
% 与之相对，调用方不要再手动加 \vspace 在两个 \centerheading 之间，
% 否则会与 before 的 20pt 叠加。
\def\centerheading#1{%
  \par\vspace*{20pt}{\centering\heiti\sanhao\bfseries #1\par}\addvspace{20pt}%
}
\def\coverlineuline#1{\underline{\makebox[12em][l]{\sihao\songti #1}}}
% 顶部分类号/密级行的点线（匹配 Word 模板的 leader dots）
\def\coverdotuline#1#2{\dotuline{\makebox[#1][l]{\sihao\songti\hspace{0.3em}#2}}}

% ============================================================
% 15. 共用环境（所有 cls 都用）
% ============================================================
% 中文摘要
\newenvironment{cnabstract}[1]{%
  \thispagestyle{cau-frontmatter}%
  \phantomsection\addcontentsline{toc}{section}{摘要}%
  \markright{摘要}%
  \centerheading{摘要}%
  \def\@cnkeywords{#1}%
  \xiaosi\songti
  \setlength{\parindent}{2em}%
  \setlength{\parskip}{0pt}%
  \par
}{%
  \par\vspace{1em}%
  {\noindent\xiaosi\songti\textbf{关键词：}\@cnkeywords}%
  \clearpage
}

% 英文摘要
\newenvironment{enabstract}[1]{%
  \thispagestyle{cau-frontmatter}%
  \phantomsection\addcontentsline{toc}{section}{Abstract}%
  \markright{Abstract}%
  \centerheading{Abstract}%
  \def\@enkeywords{#1}%
  \xiaosi
  \setlength{\parindent}{2em}%
  \setlength{\parskip}{0pt}%
  \par
}{%
  \par\vspace{1em}%
  {\noindent\xiaosi\textbf{Key words: }\@enkeywords}%
  \clearpage
}

% 目录
\newcommand{\maketoc}{%
  \thispagestyle{cau-frontmatter}%
