\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cauthesis-base}[2026/05/09 CAU Thesis common base v1.0]

% ============================================================
% 0. 各 cls 通过以下命令传入差异化内容（cls 必须在 \RequirePackage{cauthesis-base} 之前定义）
% ============================================================
% \def\cauthesis@headertext{...}    页眉左侧文本（如：中国农业大学博士学位论文）
% \def\cauthesis@type{undergraduate|master|doctor}   论文类型（影响摘要、目录等差异）

\providecommand{\cauthesis@headertext}{中国农业大学学位论文}
\providecommand{\cauthesis@type}{undergraduate}

% ============================================================
% 1. 宏包
% ============================================================
\RequirePackage{fontspec}
\RequirePackage{xeCJK}
\RequirePackage{geometry}
\RequirePackage{fancyhdr}
\RequirePackage{titlesec}
\RequirePackage{tocloft}
\RequirePackage{setspace}
\RequirePackage{caption}
\RequirePackage{booktabs}
\RequirePackage{longtable}
\RequirePackage{graphicx}
